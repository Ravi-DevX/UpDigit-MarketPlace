# Server
PORT=8080
APP_ENV=development
APP_SECRET=replace-me-with-random-string

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketplace_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=replace-access-secret
JWT_REFRESH_SECRET=replace-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Storage
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your_cf_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret
R2_BUCKET_NAME=marketplace-files
R2_S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://files.yourdomain.com

S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=marketplace-files
S3_ENDPOINT=

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
TEBEX_HEADLESS_ENABLED=false
TEBEX_PUBLIC_TOKEN=
TEBEX_PRIVATE_KEY=
TEBEX_HEADLESS_API_URL=https://headless.tebex.io/api
TEBEX_CURRENCY=USD

# Platform
PLATFORM_FEE_PERCENT=10
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# DGEN Auth
DGEN_CLIENT_ID=
DGEN_CLIENT_SECRET=
DGEN_REDIRECT_URI=http://localhost:3000/auth/callback
DGEN_ISSUER=https://auth.dgenx.net
DGEN_AUTHORIZE_URL=https://auth.dgenx.net/authorize
DGEN_TOKEN_URL=https://auth.dgenx.net/api/token
DGEN_USERINFO_URL=https://auth.dgenx.net/api/user
